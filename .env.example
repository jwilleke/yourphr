# .env.example — copy to .env and fill in for your deployment (#96).
#
#   cp .env.example .env
#
# .env is gitignored (your instance-specific values); this template is committed.
# NEVER put real secrets/keys in .env.example — only here-are-the-variables placeholders.
#
# Two kinds of variables live here:
#   1. docker-compose substitution vars — read from .env by `docker compose` (see docker-compose.yml)
#   2. FASTEN_* app config overrides — read by the backend (prefix FASTEN; '.'/'-' become '_'),
#      e.g. config key `jwt.issuer.key` -> env `FASTEN_JWT_ISSUER_KEY`.

# --- docker-compose (docker-compose.yml) ---
# Container hostname (appears in logs / the app footer).
HOSTNAME=fasten
# Host bind IP and published port. PORT maps to the container's :8080.
IP=0.0.0.0
PORT=9090

# --- deployment / reverse proxy (instance-specific) ---
# Your domain when fronting the app with a reverse proxy (e.g. Traefik/nginx + forward-auth).
domainname=example.com

# --- app config overrides (FASTEN_*; override config.yaml) ---
# SECURITY: pin your own JWT signing key instead of the public default placeholder.
#   generate: openssl rand -hex 32
# Leave UNSET to auto-generate + persist a strong key at <db-dir>/.jwt_issuer_key (#102).
# FASTEN_JWT_ISSUER_KEY=

# SQLite DB encryption key (DB encryption is on by default).
# FASTEN_DATABASE_ENCRYPTION_KEY=

# Where the SQLite DB lives (inside the container).
# FASTEN_DATABASE_LOCATION=/opt/fasten/db/fasten.db

# Backend listen port inside the container (default 8080).
# FASTEN_WEB_LISTEN_PORT=8080

# App log level: DEBUG | INFO | WARN | ERROR
# FASTEN_LOG_LEVEL=INFO
